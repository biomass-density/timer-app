# Copy this file to `.env` and paste your Gemini API key below.
# `.env` is gitignored, so your key is never committed.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — override the model (default: gemini-flash-lite-latest)
# GEMINI_MODEL=gemini-2.5-flash

# Optional — production server port (default: 3000)
# PORT=3000
